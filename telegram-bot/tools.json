[
    {
        "type": "function",
        "function": {
            "name": "create_account",
            "description": "Create a Wema account after collecting first name, last name, email, optional phone number, and PIN. Ask for the PIN only after all other fields are complete.",
            "parameters": {
                "type": "object",
                "properties": {
                    "first_name": {"type": "string"},
                    "last_name": {"type": "string"},
                    "email": {"type": "string", "format": "email"},
                    "phone_no": {"type": "integer"},
                    "pin": {"type": "string", "minLength": 4, "maxLength": 20}
                },
                "required": ["first_name", "last_name", "email", "pin"]
            }
        }
    },
    {
        "type": "function",
        "function": {
            "name": "update_account",
            "description": "Update an account email address or phone number.",
            "parameters": {
                "type": "object",
                "properties": {
                    "account_number": {"type": "integer"},
                    "email": {"type": "string", "format": "email"},
                    "phone_no": {"type": "integer"}
                },
                "required": ["account_number"]
            }
        }
    },
    {
        "type": "function",
        "function": {
            "name": "get_statement",
            "description": "Retrieve recent transfers for an account.",
            "parameters": {
                "type": "object",
                "properties": {
                    "account_number": {"type": "integer"},
                    "limit": {"type": "integer"},
                    "role": {"type": "string", "enum": ["sender", "receiver"]}
                },
                "required": ["account_number"]
            }
        }
    },
    {
        "type": "function",
        "function": {
            "name": "create_transfer",
            "description": "Transfer funds between Wema accounts after PIN confirmation.",
            "parameters": {
                "type": "object",
                "properties": {
                    "sender_acc": {"type": "integer"},
                    "receiver_acc": {"type": "integer"},
                    "amount": {"type": "integer", "minimum": 1},
                    "pin": {"type": "string", "minLength": 4},
                    "comment": {"type": "string", "maxLength": 250}
                },
                "required": ["sender_acc", "receiver_acc", "amount", "pin"]
            }
        }
    }
]
