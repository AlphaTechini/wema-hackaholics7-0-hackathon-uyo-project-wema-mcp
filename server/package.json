{
	"type": "module",
	"dependencies": {
		"@modelcontextprotocol/sdk": "1.29.0",
		"argon2": "^0.44.0",
		"dotenv": "^17.4.2",
		"drizzle-orm": "1.0.0-rc.4",
		"fastify": "^5.10.0",
		"postgres": "^3.4.9",
		"zod": "4.4.3"
	},
	"scripts": {
		"build": "tsc && node copy-mcp-instructions.mjs",
		"db:migrate": "tsx db/migrate.ts",
		"db:generate": "pnpm drizzle-kit generate --dialect=postgresql --schema=db/schema.ts --out=db/migrations",
		"seed:users": "tsx scripts/seed-users.ts",
		"dev": "tsx server.ts",
		"start": "node dist/server.js",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@types/node": "^26.1.1",
		"drizzle-kit": "1.0.0-rc.4",
		"tsx": "^4.23.1",
		"typescript": "^7.0.2"
	}
}
